# REQUIRED: Telegram Bot Token from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ─── Performance Tuning ─────────────────────────────────────────────
N_CHUNKS=2               # Number of parallel chunk sessions
WORKERS_PER_CHUNK=8      # Workers per chunk (max 20)
MIN_DELAY=1.5            # Normal delay between requests (seconds)
MAX_DELAY=3.0
MAX_RESULTS=10           # Max results per page (1-50)

# ─── Proxy & Tor ────────────────────────────────────────────────────
PROXY_ENABLED=true       # Set to false to disable proxy pool globally
# PROXY_LIST=http://user:pass@host:8080,socks5://host:1080   # Comma-separated proxies (optional)
TOR_PROXY=socks5://127.0.0.1:9050   # Default Tor SOCKS proxy

# ─── Debugging ──────────────────────────────────────────────────────
DEBUG_HTML=0             # Set to 1 to save raw HTML when no URLs are found
